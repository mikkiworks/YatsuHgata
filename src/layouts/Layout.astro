---
// src/layouts/Layout.astro
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---
<html lang="ja">
<head>
	<meta charset="utf-8" />
	<meta name="viewport" content="width=device-width" />
	<meta name="generator" content={Astro.generator} />
	<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
	<link rel="icon" href="/favicon.ico" />
	<link rel="preconnect" href="https://fonts.googleapis.com">
	<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
	<link href="https://fonts.googleapis.com/css2?family=Noto+Serif+JP:wght@400;700&display=swap" rel="stylesheet">
	<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" />
	<title>谷津干潟ナビ</title>
</head>

<body>

<div class="wrapper">

	<!-- グローバルナビ -->
	<header class="sidebar">
		<h1>
			<a href="/" class="logo">
				<img class="logo__item" src="/src/assets/logo.png" alt="谷津干潟ナビのロゴ">
			</a>
		</h1>
		<nav class="gnavi dotted-line-btm">
			<a href="/news" class="gnavi__item">
				<span class="gnavi__item__eng">NEWS</span>
				最新情報
			</a>
			<a href="/about" class="gnavi__item">
				<span class="gnavi__item__eng">ABOUT</span>
				谷津干潟とは
			</a>
			<a href="/guide" class="gnavi__item">
				<span class="gnavi__item__eng">GUIDE</span>
				観察・散策ガイド
			</a>
			<a href="/access" class="gnavi__item">
				<span class="gnavi__item__eng">ACCESS</span>
				アクセス
			</a>
			<a href="#" class="gnavi__item">
				<span class="gnavi__item__eng">CONTACT</span>
				お問い合わせ
			</a>
		</nav>
	</header>

	<!-- コンテンツ -->
	<main class="main">
		<slot />
		<Footer/>
	</main>

</div>
</body>
</html>

<style>
/* ==========================================================================
	Layout
   ========================================================================== */
.wrapper {
	display: flex;
	flex-direction: row;
	min-height: 100vh;
}

/**** サイドバー ****/
.sidebar {
	width: 250px;
	height: 100vh;
	position: sticky;
	top: 0;
	border-right: 1px solid #ECECEC;
	overflow-y: auto; /* サイドバー内が長い場合はスクロール可能に */

	/* ロゴ */
	& .logo {
		display: block;
		width: 100%;
		padding: 70px 0 70px 0;
		text-align: center;
	}
	& .logo__item {
		display: inline;
		width: 155px;
	}

	/* グローバルナビ */
	& .gnavi__item {
		position: relative;
		display: block;
		padding: 20px 0 20px 30px;
		background-image: linear-gradient(to right, #DADADA 20%, rgba(255, 255, 255, 0) 0%);
		background-size: 5px 1px;
		background-repeat: repeat-x;
		background-position: top;
		line-height: 1.2;
		letter-spacing: 0.5px;
		font-size: 1.1rem;
		font-family: var(--font-family-serif);
		&::after {
			position: absolute;
			right: 30px;
			font-family: 'Material Symbols Outlined';
			content: '\e5cc';
			font-size: 14px;
		}
	}

	& .gnavi__item__eng {
		display: block;
		font-size: 0.7rem;
		color: #8EC0E5;
		letter-spacing: 1.35px;
	}
}

.main {
	flex: 1;
	min-width: 0; 
}

/* SP版（例: 768px以下） */
@media (max-width: 768px) {

}
</style>